FROM ubuntu:24.04 AS build
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git curl wget ca-certificates tzdata \
    libssl-dev gcc g++ \
    libavcodec-dev libavformat-dev libavutil-dev libswscale-dev libavfilter-dev \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/media
COPY . /opt/media/ZLMediaKit
WORKDIR /opt/media/ZLMediaKit/3rdpart
RUN wget -q https://github.com/cisco/libsrtp/archive/v2.3.0.tar.gz -O libsrtp-2.3.0.tar.gz && \
    tar xf libsrtp-2.3.0.tar.gz && mv libsrtp-2.3.0 libsrtp && \
    cd libsrtp && CFLAGS="-fcommon" ./configure --enable-openssl && make -j$(nproc) && make install

RUN mkdir -p /opt/media/ZLMediaKit/build
WORKDIR /opt/media/ZLMediaKit/build
RUN cmake -DENABLE_FFMPEG=ON -DCMAKE_BUILD_TYPE=Release \
          -DENABLE_WEBRTC=OFF -DENABLE_TESTS=OFF -DENABLE_API=OFF \
          -DENABLE_PYTHON=OFF .. && \
    make -j$(nproc)

FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates tzdata curl ffmpeg \
    libavcodec-dev libavformat-dev libavutil-dev libswscale-dev libavfilter-dev \
    && rm -rf /var/lib/apt/lists/*

ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone && \
    mkdir -p /opt/media/bin/www /opt/media/conf

WORKDIR /opt/media/bin/
COPY --from=build /opt/media/ZLMediaKit/release/linux/Release/MediaServer /opt/media/bin/
COPY --from=build /opt/media/ZLMediaKit/release/linux/Release/config.ini /opt/media/conf/
COPY --from=build /opt/media/ZLMediaKit/www/ /opt/media/bin/www/
CMD ["./MediaServer", "-c", "../conf/config.ini", "-l", "1"]
